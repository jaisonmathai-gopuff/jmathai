SNOWFLAKE_ACCOUNT  = "gopuff.east-us-2.azure"
SNOWFLAKE_DATABASE = "MCP_MARTS"
SNOWFLAKE_SCHEMA   = "GOLD"
SNOWFLAKE_ROLE     = "MCP_SERVICE_ROLE"
SNOWFLAKE_WH       = "MCP_SERVICE_WH"

# Simulation defaults (all overridable via CLI)
DEFAULT_LOOKBACK_DAYS = 90      # demand history window
DEFAULT_N_SIMS        = 2000    # paths per intersection (use 5000 for final runs)
DEFAULT_TARGET_SL     = 0.95    # fraction of paths that must meet OOS tolerance
DEFAULT_SS_MIN        = 3       # minimum SS days to scan
DEFAULT_SS_MAX        = 21      # maximum SS days to scan
DEFAULT_MAX_WORKERS   = 4       # parallel Snowflake fetch threads

# OOS tolerance by CX quintile — max acceptable OOS days in the simulation window.
# Recommendation = min SS where (paths with OOS ≤ tolerance) / total paths >= TARGET_SL.
# NULL quintile is treated as Q3.
QUINTILE_OOS_TOLERANCE: Dict[Optional[int], int] = {
    1: 1,
    2: 1,
    3: 3,
    4: 4,
    5: 4,
    None: 3,
}


# ─────────────────────────────────────────────────────────────────────────────
# DATA CLASSES
