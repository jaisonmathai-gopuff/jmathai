@dataclass
class IntersectionData:
    """All inputs required to run one Monte Carlo."""
    product_id:       int
    location_id:      int
    product_name:     str            = ""
    location_name:    str            = ""
    case_size:        int            = 1
    delivery_dows:    set            = field(default_factory=lambda: {2, 5})  # Tue, Fri
    daily_demand:     Dict           = field(default_factory=dict)  # date_str → units
    fill_rates:       List[float]    = field(default_factory=list)
    cx_quintile:      Optional[int]  = None
    profit_cubic_q:   Optional[int]  = None
    sc_quintile:      Optional[int]  = None
    oos_tolerance:    int            = 3   # max acceptable OOS days (from quintile)
    kinaxis_policy:   str            = "unknown"
    kinaxis_ss_days:  int            = 0
    l13w_revenue:     float          = 0.0
    oos_pct:          float          = 0.0
    error:            str            = ""


@dataclass
class SimResult:
    """Output from one product × location simulation sweep."""
    product_id:           int
    location_id:          int
    product_name:         str
    location_name:        str
    case_size:            int
    delivery_dows:        str
    cx_quintile:          Optional[int]
    profit_cubic_q:       Optional[int]
    sc_quintile:          Optional[int]
    oos_tolerance:        int
    target_sl_pct:        float          # target SL % used for this intersection
    kinaxis_policy:       str
    kinaxis_ss_days:      int
    l13w_revenue:         float
    oos_pct:              float
    demand_mean:          float
    demand_std:           float
    fill_rate_mean:       float
    fill_rate_std:        float
    n_demand_days:        int
    n_deliveries:         int
    recommended_ss_days:  int            # min SS to hit target SL at oos_tolerance
    recommended_sl:       float          # achieved SL at recommended SS
    current_sl:           float          # SL at current Kinaxis policy level
    delta_ss_days:        int            # recommended − current
    recommended_avg_stgt: float
    recommended_cases:    int
    current_avg_stgt:     float
    current_cases:        int
    full_sweep:           Dict           # {ss_days: {sl0, sl1, sl_tol, avg_stgt, cases}}
    error:                str            = ""


