# CLI ENTRY POINT
# ─────────────────────────────────────────────────────────────────────────────

def parse_args():
    p = argparse.ArgumentParser(
        description="Batch safety stock Monte Carlo — quintile-aware OOS tolerance"
    )
    p.add_argument("--user",              required=True,
                   help="Snowflake username (email)")
    p.add_argument("--password",          default=None,
                   help="Snowflake password (omit for SSO browser pop-up)")
    p.add_argument("--candidates",        default=None,
                   help="CSV with product_id, location_id columns")
    p.add_argument("--auto-candidates",   action="store_true",
                   help="Pull all-quintile candidates from Snowflake automatically")
    p.add_argument("--location-ids",      default="258,37,690,265,99",
                   help="Comma-separated location IDs for --auto-candidates")
    p.add_argument("--lookback-days",     type=int,   default=DEFAULT_LOOKBACK_DAYS)
    p.add_argument("--n-sims",            type=int,   default=DEFAULT_N_SIMS)
    p.add_argument("--target-sl",         type=float, default=DEFAULT_TARGET_SL,
                   help="Fraction of paths that must meet OOS tolerance (default 0.95)")
    p.add_argument("--ss-min",            type=int,   default=DEFAULT_SS_MIN)
    p.add_argument("--ss-max",            type=int,   default=DEFAULT_SS_MAX)
    p.add_argument("--max-workers",       type=int,   default=DEFAULT_MAX_WORKERS)
    p.add_argument("--out-dir",           default="results")
    return p.parse_args()


def main():
    args = parse_args()
    np.random.seed(42)

    print(f"\n{'═'*60}")
    print(f"  Batch SS Monte Carlo  (quintile-aware OOS tolerance)")
    print(f"  User: {args.user}")
    print(f"  Lookback: {args.lookback_days}d  |  Sims: {args.n_sims:,}  "
          f"|  Target SL: {args.target_sl:.0%}")
    print(f"  OOS tolerance: Q1/Q2→1d, Q3/NULL→3d, Q4/Q5→4d")
    print(f"{'═'*60}")

    # 1. Connect
    print("\n[1/4] Connecting to Snowflake...")
    conn = get_connection(args.user, args.password)
    print("      Connected.")

    fetcher = DataFetcher(conn, lookback_days=args.lookback_days)
    engine  = SimulationEngine(
        n_sims       = args.n_sims,
        ss_scenarios = list(range(args.ss_min, args.ss_max + 1)),
        target_sl    = args.target_sl,
    )
    runner = BatchRunner(fetcher, engine, max_workers=args.max_workers)

    # 2. Load candidates
    print("\n[2/4] Loading candidates...")
    if args.auto_candidates:
        loc_ids = [int(x) for x in args.location_ids.split(",")]
        print(f"      Pulling all-quintile pairs for locations {loc_ids}...")
        candidates = fetcher.get_auto_candidates(loc_ids)
    elif args.candidates:
        candidates = pd.read_csv(args.candidates)
    else:
        print("ERROR: provide --candidates FILE or --auto-candidates", file=sys.stderr)
        sys.exit(1)

    print(f"      {len(candidates)} intersections loaded.")
    if "cx_quintile_location" in candidates.columns:
        dist = candidates["cx_quintile_location"].value_counts(dropna=False).sort_index()
        print(f"      Quintile distribution:\n{dist.to_string()}")

    # 3. Run
    print("\n[3/4] Running simulations...")
    results = runner.run(candidates)

    # 4. Write
    print("\n[4/4] Writing outputs...")
    df = runner.to_dataframe(results)
    runner.write_outputs(df, out_dir=args.out_dir)

    # Summary stats
    ok   = df[df["error"] == ""]
    err  = df[df["error"] != ""]
    high = ok[ok["priority"].str.contains("HIGH", na=False)]
    print(f"\n{'─'*60}")
    print(f"  Completed: {len(ok)}/{len(df)}  |  Errors: {len(err)}")
    if len(ok):
        print(f"  HIGH priority (OOS>5% + SS gap): {len(high)}")
        print(f"  Avg delta SS days (all OK): {ok['delta_ss_days'].mean():+.1f}d")
        for q in [1, 2, 3, 4, 5]:
            sub = ok[ok["cx_quintile"] == q]
            if len(sub):
                print(f"  Q{q} ({len(sub)} products): "
                      f"avg delta {sub['delta_ss_days'].mean():+.1f}d  "
                      f"| tol={QUINTILE_OOS_TOLERANCE[q]}d OOS")
    print(f"{'─'*60}\n")

    conn.close()


if __name__ == "__main__":
    main()

